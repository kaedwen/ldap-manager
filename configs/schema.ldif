# LDAP Schema Extension for Password Reset Functionality
#
# Installation:
#   ldapadd -Y EXTERNAL -H ldapi:/// -f schema.ldif
#
# Note: The OID prefix 1.3.6.1.4.1.99999 is a placeholder.
# In production, you should use your organization's registered OID
# or a private enterprise number.

dn: cn=pwdreset,cn=schema,cn=config
objectClass: olcSchemaConfig
cn: pwdreset
olcAttributeTypes: ( 1.3.6.1.4.1.99999.1.1.1
  NAME 'pwdResetToken'
  DESC 'Password reset token hash (SHA-256)'
  EQUALITY caseExactMatch
  SYNTAX 1.3.6.1.4.1.1466.115.121.1.15
  SINGLE-VALUE )
olcAttributeTypes: ( 1.3.6.1.4.1.99999.1.1.2
  NAME 'pwdResetExpiry'
  DESC 'Password reset token expiry timestamp (Unix epoch)'
  EQUALITY integerMatch
  SYNTAX 1.3.6.1.4.1.1466.115.121.1.27
  SINGLE-VALUE )
olcObjectClasses: ( 1.3.6.1.4.1.99999.1.2.1
  NAME 'pwdResetAccount'
  DESC 'Auxiliary class for password reset functionality'
  AUXILIARY
  MAY ( pwdResetToken $ pwdResetExpiry ) )
